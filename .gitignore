```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/

# Dependencies
.venv/
venv/
node_modules/

# Logs and temp files
*.log
*.tmp
*.swp

# Environment
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/

# Coverage
.coverage
coverage/
htmlcov/

# Python specific
*.pyo
*.pyd
*.so
*.egg-info/
.Python
pip-log.txt
pip-delete-this-directory.txt

# System files
.DS_Store
Thumbs.db
```